# 應用程式設定（videogirl）
# 複製此檔案為 .env 並填入實際值。
# 注意：Coolify / Docker --env-file 會把引號當成值的一部分，所以本檔案不加引號。

# Telegram Bot Token（向 @BotFather 申請）
telegram_token=your_telegram_bot_token

# 資料庫與快取（開發環境預設對應 docker-compose.dev.yml）
postgres_url=postgresql://videogirl:videogirl@localhost:5432/videogirl
redis_url=redis://localhost:6379/0

# 外部服務位址
ollama_base_url=http://192.168.1.100:11434
comfyui_base_url=http://ai.bygpu.com:8188
# ComfyUI Station Gateway（task #10）：worker 統一由此生成圖片/影片。
comfyui_gateway_url=http://127.0.0.1:9188
# 須與 comfyui-station/.env 的 STATION_TOKEN 一致。
comfyui_gateway_token=change-me
# BreezyVoice accepts this native setting name, or BREEZYVOICE_URL in Coolify.
breezyvoice_base_url=https://breezyvoice.momooai.com
breezyvoice_token=

# 模型設定
embedding_model=BAAI/bge-m3
# 給 Ollama 用的完整模型 tag
model_name=hf.co/HauhauCS/Qwen3.5-9B-Uncensored-HauhauCS-Aggressive:Q4_K_M

# --- 可切換 LLM 後端(見 shared/llm.py)---
# active profile:mac-qwen9b(預設) / mac-gemma / 4090-vllm / kimi / openrouter
llm_profile=mac-qwen9b
llm_timeout_secs=120
llm_max_retries=3
# 只有切到 OpenAI 相容後端(4090 vLLM / Kimi / OpenRouter)時才需要填:
openai_compat_base_url=
openai_compat_api_key=
openai_compat_model=
vllm_base_url=

# Admin 後台
admin_username=admin
admin_password=change-me-in-production
admin_secret_key=change-me-in-production
admin_host=0.0.0.0
admin_port=3000

# VIP 月訂閱 (task #21)
vip_amount_stars=199
vip_subscription_period_seconds=2592000
vip_grace_period_seconds=259200

# 日誌等級
log_level=INFO
